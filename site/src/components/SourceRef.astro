---
interface Props {
  source: string;
  location?: string;
  status?: string;
  href?: string;
  layer?: string;
}

const { source, location = '', status = 'needs verification', href = '', layer = 'source' } = Astro.props;
const sourceKey = source.toLowerCase();
const autoLinks = [
  ['radiation, light and illumination', '/Charles-Proteus-Steinmetz-Texts-AI-Decoded/sources/radiation-light-and-illumination/'],
  ['elementary lectures', '/Charles-Proteus-Steinmetz-Texts-AI-Decoded/sources/elementary-lectures-electric-discharges-waves-impulses/'],
  ['engineering mathematics', '/Charles-Proteus-Steinmetz-Texts-AI-Decoded/sources/engineering-mathematics/'],
  ['transient electric phenomena', '/Charles-Proteus-Steinmetz-Texts-AI-Decoded/sources/theory-calculation-transient-electric-phenomena-oscillations/'],
  ['alternating current phenomena', '/Charles-Proteus-Steinmetz-Texts-AI-Decoded/sources/theory-calculation-alternating-current-phenomena/'],
  ['theoretical elements', '/Charles-Proteus-Steinmetz-Texts-AI-Decoded/sources/theoretical-elements-electrical-engineering/'],
  ['general lectures', '/Charles-Proteus-Steinmetz-Texts-AI-Decoded/sources/general-lectures-electrical-engineering/'],
  ['electric apparatus', '/Charles-Proteus-Steinmetz-Texts-AI-Decoded/sources/theory-calculation-electric-apparatus/'],
  ['america and the new epoch', '/Charles-Proteus-Steinmetz-Texts-AI-Decoded/sources/america-and-new-epoch/'],
  ['relativity and space', '/Charles-Proteus-Steinmetz-Texts-AI-Decoded/sources/four-lectures-relativity-space/'],
  ['commonwealth edison', '/Charles-Proteus-Steinmetz-Texts-AI-Decoded/sources/commonwealth-edison-generating-system-trouble/']
] as const;
const resolvedHref = href || autoLinks.find(([needle]) => sourceKey.includes(needle))?.[1] || '';

const normalizedStatus = status.toLowerCase();
let confidence = 'needs review';
if (normalizedStatus.includes('seeded') || normalizedStatus.includes('promoted') || normalizedStatus.includes('source-located')) {
  confidence = 'source-located';
}
if (normalizedStatus.includes('candidate') || normalizedStatus.includes('ocr')) {
  confidence = 'OCR candidate';
}
if (normalizedStatus.includes('raw')) {
  confidence = 'raw custody';
}
if (normalizedStatus.includes('verified')) {
  confidence = 'verified';
}
---

<aside class="source-ref" data-layer={layer}>
  <strong>Source:</strong> {source}
  {location && <> - <strong>Location:</strong> {location}</>}
  <span class="verification-label" data-confidence={confidence}>{status}</span>
  {resolvedHref && <a class="source-ref-link" href={resolvedHref}>View source record</a>}
</aside>
