<div class="tool-shell" data-impedance-tool>
  <div class="tool-grid">
    <div class="tool-controls">
      <label>
        Resistance R
        <input data-resistance type="range" min="1" max="100" step="1" value="45" />
      </label>
      <label>
        Reactance X
        <input data-reactance type="range" min="-100" max="100" step="1" value="55" />
      </label>
      <div class="tool-readout" data-readout></div>
    </div>
    <canvas class="tool-canvas" data-canvas width="900" height="320"></canvas>
  </div>
</div>

<script>
  function drawTriangle(canvas, resistance, reactance) {
    const ctx = canvas.getContext('2d');
    const width = canvas.width;
    const height = canvas.height;
    const originX = 120;
    const originY = height / 2;
    const scale = 2.1;
    const endX = originX + resistance * scale;
    const endY = originY - reactance * scale;

    ctx.clearRect(0, 0, width, height);
    ctx.fillStyle = '#fcfbf8';
    ctx.fillRect(0, 0, width, height);

    ctx.strokeStyle = '#ddd8cd';
    ctx.lineWidth = 1;
    for (let x = 0; x <= width; x += 60) {
      ctx.beginPath();
      ctx.moveTo(x, 0);
      ctx.lineTo(x, height);
      ctx.stroke();
    }
    for (let y = 40; y <= height; y += 40) {
      ctx.beginPath();
      ctx.moveTo(0, y);
      ctx.lineTo(width, y);
      ctx.stroke();
    }

    ctx.strokeStyle = '#4f554f';
    ctx.lineWidth = 2;
    ctx.beginPath();
    ctx.moveTo(40, originY);
    ctx.lineTo(width - 40, originY);
    ctx.stroke();

    ctx.strokeStyle = '#a9822a';
    ctx.lineWidth = 5;
    ctx.beginPath();
    ctx.moveTo(originX, originY);
    ctx.lineTo(endX, originY);
    ctx.stroke();

    ctx.strokeStyle = '#9b4d32';
    ctx.lineWidth = 5;
    ctx.beginPath();
    ctx.moveTo(endX, originY);
    ctx.lineTo(endX, endY);
    ctx.stroke();

    ctx.strokeStyle = '#2f6f67';
    ctx.lineWidth = 6;
    ctx.beginPath();
    ctx.moveTo(originX, originY);
    ctx.lineTo(endX, endY);
    ctx.stroke();

    ctx.fillStyle = '#1c2422';
    ctx.font = '700 24px system-ui, sans-serif';
    ctx.fillText('R', originX + resistance * scale / 2 - 8, originY + 34);
    ctx.fillText('X', endX + 18, originY - reactance * scale / 2 + 8);
    ctx.fillText('Z', originX + resistance * scale / 2 + 18, originY - reactance * scale / 2 - 16);
  }

  document.querySelectorAll('[data-impedance-tool]').forEach((tool) => {
    const resistanceInput = tool.querySelector('[data-resistance]');
    const reactanceInput = tool.querySelector('[data-reactance]');
    const readout = tool.querySelector('[data-readout]');
    const canvas = tool.querySelector('[data-canvas]');

    function render() {
      const resistance = Number(resistanceInput.value);
      const reactance = Number(reactanceInput.value);
      const magnitude = Math.hypot(resistance, reactance);
      const angle = Math.atan2(reactance, resistance) * 180 / Math.PI;
      const sign = reactance >= 0 ? '+' : '-';
      readout.innerHTML = `
        <strong>Original frame:</strong> resistance and reactance as a symbolic quantity<br />
        <strong>Modern form:</strong> Z = ${resistance.toFixed(0)} ${sign} j${Math.abs(reactance).toFixed(0)}<br />
        <strong>Magnitude:</strong> ${magnitude.toFixed(2)} ohms<br />
        <strong>Phase angle:</strong> ${angle.toFixed(1)} degrees
      `;
      drawTriangle(canvas, resistance, reactance);
    }

    resistanceInput.addEventListener('input', render);
    reactanceInput.addEventListener('input', render);
    render();
  });
</script>
