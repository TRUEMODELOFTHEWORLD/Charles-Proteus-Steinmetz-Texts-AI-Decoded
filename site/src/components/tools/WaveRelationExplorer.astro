<div class="tool-shell" data-wave-tool>
  <div class="tool-grid">
    <div class="tool-controls">
      <label>
        Frequency in hertz
        <input data-frequency type="range" min="1" max="15" step="0.01" value="1.778" />
      </label>
      <label>
        Display amplitude
        <input data-amplitude type="range" min="10" max="90" step="1" value="48" />
      </label>
      <div class="tool-readout" data-readout></div>
    </div>
    <canvas class="tool-canvas" data-canvas width="900" height="320"></canvas>
  </div>
</div>

<script>
  const SPEED = 299_792_458;

  function formatMetric(value) {
    if (value >= 1000) return `${(value / 1000).toLocaleString(undefined, { maximumFractionDigits: 2 })} km`;
    if (value >= 1) return `${value.toLocaleString(undefined, { maximumFractionDigits: 2 })} m`;
    if (value >= 0.01) return `${(value * 100).toLocaleString(undefined, { maximumFractionDigits: 2 })} cm`;
    return `${(value * 1000).toLocaleString(undefined, { maximumFractionDigits: 2 })} mm`;
  }

  function labelFrequency(logValue) {
    const frequency = 10 ** Number(logValue);
    if (frequency >= 1e12) return `${(frequency / 1e12).toFixed(2)} THz`;
    if (frequency >= 1e9) return `${(frequency / 1e9).toFixed(2)} GHz`;
    if (frequency >= 1e6) return `${(frequency / 1e6).toFixed(2)} MHz`;
    if (frequency >= 1e3) return `${(frequency / 1e3).toFixed(2)} kHz`;
    return `${frequency.toFixed(2)} Hz`;
  }

  function draw(canvas, frequency, amplitude) {
    const ctx = canvas.getContext('2d');
    const width = canvas.width;
    const height = canvas.height;
    ctx.clearRect(0, 0, width, height);
    ctx.fillStyle = '#fcfbf8';
    ctx.fillRect(0, 0, width, height);

    ctx.strokeStyle = '#ddd8cd';
    ctx.lineWidth = 1;
    for (let x = 0; x <= width; x += 60) {
      ctx.beginPath();
      ctx.moveTo(x, 0);
      ctx.lineTo(x, height);
      ctx.stroke();
    }
    for (let y = 40; y <= height; y += 40) {
      ctx.beginPath();
      ctx.moveTo(0, y);
      ctx.lineTo(width, y);
      ctx.stroke();
    }

    const mid = height / 2;
    ctx.strokeStyle = '#4f554f';
    ctx.lineWidth = 2;
    ctx.beginPath();
    ctx.moveTo(0, mid);
    ctx.lineTo(width, mid);
    ctx.stroke();

    const cycles = Math.max(1, Math.min(12, Math.log10(frequency) + 1));
    ctx.strokeStyle = '#2f6f67';
    ctx.lineWidth = 4;
    ctx.beginPath();
    for (let x = 0; x <= width; x += 2) {
      const y = mid + Math.sin((x / width) * cycles * Math.PI * 2) * amplitude;
      if (x === 0) ctx.moveTo(x, y);
      else ctx.lineTo(x, y);
    }
    ctx.stroke();

    ctx.strokeStyle = '#9b4d32';
    ctx.lineWidth = 2;
    ctx.setLineDash([8, 8]);
    ctx.beginPath();
    ctx.moveTo(0, mid - amplitude);
    ctx.lineTo(width, mid - amplitude);
    ctx.moveTo(0, mid + amplitude);
    ctx.lineTo(width, mid + amplitude);
    ctx.stroke();
    ctx.setLineDash([]);
  }

  document.querySelectorAll('[data-wave-tool]').forEach((tool) => {
    const frequencyInput = tool.querySelector('[data-frequency]');
    const amplitudeInput = tool.querySelector('[data-amplitude]');
    const readout = tool.querySelector('[data-readout]');
    const canvas = tool.querySelector('[data-canvas]');

    function render() {
      const frequency = 10 ** Number(frequencyInput.value);
      const amplitude = Number(amplitudeInput.value);
      const wavelength = SPEED / frequency;
      readout.innerHTML = `
        <strong>Frequency:</strong> ${labelFrequency(frequencyInput.value)}<br />
        <strong>Wavelength:</strong> ${formatMetric(wavelength)}<br />
        <strong>Relation:</strong> wavelength = speed / frequency
      `;
      draw(canvas, frequency, amplitude);
    }

    frequencyInput.addEventListener('input', render);
    amplitudeInput.addEventListener('input', render);
    render();
  });
</script>
